{
  "name": "@coroboros/location-timezone",
  "version": "1.0.0",
  "description": "Capital, country, city, ANSI state, and IANA timezone lookups for Node.js.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsdown",
    "build:data": "node scripts/clean-and-generate.js",
    "bench": "pnpm build && node bench/location-timezone.bench.mjs",
    "dev": "tsdown --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "keywords": [
    "coroboros",
    "location",
    "timezone",
    "city",
    "capital",
    "country",
    "province",
    "state",
    "iso-3166",
    "ansi",
    "iana",
    "nodejs"
  ],
  "author": "Coroboros <ob@coroboros.com> (https://github.com/coroboros)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coroboros/location-timezone.git"
  },
  "bugs": {
    "url": "https://github.com/coroboros/location-timezone/issues"
  },
  "homepage": "https://github.com/coroboros/location-timezone#readme",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.1.3",
  "publishConfig": {
    "access": "public"
  },
  "private": false,
  "preferGlobal": false,
  "analyze": false,
  "dependencies": {
    "zipson": "^0.2.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.7",
    "country-locale-map": "^1.9.12",
    "fast-check": "^4.8.0",
    "joi": "^18.2.1",
    "mitata": "^1.0.34",
    "tsdown": "^0.22.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
